# Copiar a .env y rellenar con tus valores.
# Ver también env-example-backend.txt en la raíz del proyecto.

# Base de datos: usar Supabase (dejar USE_LOCAL_DB sin definir o false) o PostgreSQL local
# USE_LOCAL_DB=true

# PostgreSQL local (solo si USE_LOCAL_DB=true)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=maintenance_db
# DB_USER=postgres
# DB_PASSWORD=password

# Servidor
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# JWT (obligatorio)
JWT_SECRET=tu_jwt_secret_muy_seguro

# Supabase (obligatorio si no usas USE_LOCAL_DB=true)
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key

# Pruebas npm run test:supabase (usuario debe existir en Supabase Auth)
TEST_EMAIL=un_usuario_valido@tudominio.com
TEST_PASSWORD=tu_contraseña

# Opcional para el script de pruebas
# API_URL=http://localhost:3000
