{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install && npx update-browserslist-db@latest && cd server && npm install",
  "functions": {
    "api/index.js": {
      "maxDuration": 30
    },
    "api/pagos.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/pagos/:path*", "destination": "/api/pagos" },
    { "source": "/api/:path*", "destination": "/api" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "framework": null
}
