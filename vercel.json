{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install && npx update-browserslist-db@latest && cd server && npm install",
  "functions": {
    "api/index.js": {
      "maxDuration": 30
    },
    "api/pagos/[...path].js": {
      "maxDuration": 30
    },
    "api/pagos/auth/login.js": {
      "maxDuration": 30
    },
    "api/pagos/auth/profile.js": {
      "maxDuration": 30
    },
    "api/pagos/bills.js": {
      "maxDuration": 30
    },
    "api/pagos/users.js": {
      "maxDuration": 30
    },
    "api/pagos/sites.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/pagos/:path*", "destination": "/api/pagos/:path*" },
    { "source": "/api/:path((?!pagos$)(?!pagos/).*)", "destination": "/api" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "framework": null
}
