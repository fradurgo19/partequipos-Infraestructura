{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install && npx update-browserslist-db@latest && cd server && npm install",
  "functions": {
    "api/index.js": {
      "maxDuration": 30
    },
    "api/pagos/[...path].js": {
      "maxDuration": 30
    },
    "api/pagos/auth/login.js": {
      "maxDuration": 30
    },
    "api/pagos/auth/profile.js": {
      "maxDuration": 30
    },
    "api/pagos/bills/index.js": {
      "maxDuration": 30
    },
    "api/pagos/bill-by-id.js": {
      "maxDuration": 30
    },
    "api/pagos/bill-status.js": {
      "maxDuration": 60
    },
    "api/pagos/bill-approve.js": {
      "maxDuration": 60
    },
    "api/pagos/users.js": {
      "maxDuration": 30
    },
    "api/pagos/sites.js": {
      "maxDuration": 30
    },
    "api/pagos/upload.js": {
      "maxDuration": 30
    },
    "api/internal-requests-public.js": {
      "maxDuration": 30
    },
    "api/upload-public.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/pagos/bills/:id/approve", "destination": "/api/pagos/bill-approve?id=:id" },
    { "source": "/api/pagos/bills/:id/status", "destination": "/api/pagos/bill-status?id=:id" },
    { "source": "/api/pagos/bills/:id", "destination": "/api/pagos/bill-by-id?id=:id" },
    { "source": "/api/pagos/:path*", "destination": "/api/pagos/:path*" },
    { "source": "/api/internal-requests/public", "destination": "/api/internal-requests-public" },
    { "source": "/api/upload/public/file", "destination": "/api/upload-public" },
    { "source": "/api/:path((?!pagos$)(?!pagos/).*)", "destination": "/api" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "framework": null
}
